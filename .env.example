# ----------------------------------------------------------
# Public (exposed to browser — must be prefixed NEXT_PUBLIC_)
# ----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Elviora
# Leave pointing to /api/v1 unless you front the app with a separate backend.
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_CDN_URL=https://cdn.elviora.com
NEXT_PUBLIC_ENVIRONMENT=development

# Analytics & 3rd party
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SENTRY_DSN=

# OAuth (client IDs only — browser-safe)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Stripe publishable key — browser-safe; pair with STRIPE_SECRET_KEY below
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ----------------------------------------------------------
# Server-only (NEVER prefix with NEXT_PUBLIC_)
# ----------------------------------------------------------
API_URL=

# Auth — generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-strong-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-strong-random-string
NEXTAUTH_SECRET=replace-me
GOOGLE_CLIENT_SECRET=

# Database (Postgres) — used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/elviora?schema=public
DIRECT_URL=

# Cache + queues (optional — app gracefully degrades when unset)
REDIS_URL=

# Email — Resend
RESEND_API_KEY=

# Payments — Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Object storage — S3 / R2 / any S3-compatible
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# AI (skin assessment)
OPENAI_API_KEY=

# Observability
SENTRY_AUTH_TOKEN=
