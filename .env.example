# ----------------------------------------------------------
# Public (exposed to browser — must be prefixed NEXT_PUBLIC_)
# ----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Elviora
# Same-origin API. Use an absolute URL only if you front the app with a separate backend.
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_CDN_URL=https://cdn.elviora.com
NEXT_PUBLIC_ENVIRONMENT=development

# Analytics & 3rd party
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
# Meta (Facebook) Pixel. Defaults to the Elviora pixel in code if left blank.
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_SENTRY_DSN=

# OAuth (client IDs only — browser-safe)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Stripe publishable key — browser-safe; pair with STRIPE_SECRET_KEY below
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ----------------------------------------------------------
# Server-only (NEVER prefix with NEXT_PUBLIC_)
# ----------------------------------------------------------
API_URL=

# Auth — generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-strong-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-strong-random-string
NEXTAUTH_SECRET=replace-me
GOOGLE_CLIENT_SECRET=

# --- DATABASE -----------------------------------------------------------
# Any Postgres works (local, Supabase, Neon, Render, RDS).
#
# Local Postgres:
#   postgresql://postgres:postgres@localhost:5432/elviora?schema=public
#
# Supabase (recommended) — copy the SESSION POOLER string from:
#   Supabase Dashboard → Connect → Connection string → Session pooler
# It looks like:
#   postgresql://postgres.<project-ref>:[PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres
# The Session pooler (port 5432) works for both runtime AND migrations.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/elviora?schema=public

# Optional. Only needed when DATABASE_URL points to a TRANSACTION pooler
# (Supabase port 6543 — required at high concurrency); migrations bypass it
# via DIRECT_URL. With the Session pooler URL above, leave this blank.
DIRECT_URL=

# Cache + queues (optional — app gracefully degrades when unset)
REDIS_URL=

# Email — Resend
RESEND_API_KEY=

# Payments — Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Object storage — S3 / R2 / any S3-compatible
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# AI (skin assessment)
OPENAI_API_KEY=

# Meta Conversions API (server-side events). Get the token from Events Manager →
# Settings → Conversions API. Leave blank to disable server-side tracking.
META_CAPI_ACCESS_TOKEN=
# Optional: routes CAPI events to Events Manager → Test events while wiring up.
META_CAPI_TEST_EVENT_CODE=

# Observability
# Set NEXT_PUBLIC_SENTRY_DSN (above) to enable error reporting at runtime.
# The three below are only needed in CI/production to upload source maps.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
