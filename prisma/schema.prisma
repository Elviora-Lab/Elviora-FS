// =============================================================================
//  Elviora — Database Schema
//  Single source of truth (Prisma) → PostgreSQL.
//
//  Conventions:
//   • Tables and columns are snake_case in the DB (via @@map / @map).
//   • Primary keys are UUID v4 generated DB-side (gen_random_uuid()).
//   • Money fields use Decimal(12,2) for storefront and 6 decimals for FX rates.
//   • All timestamps are TIMESTAMPTZ — store UTC, render in user locale.
//   • Foreign keys are explicitly indexed (Postgres does not index FKs by default).
//   • onDelete: Cascade for owned children; SetNull for soft references
//     (e.g. order_items keep their snapshot when product is removed).
//   • Composite uniques and partial indexes are used to guard data integrity
//     (one default address per user, one active cart per session, etc).
// =============================================================================

generator client {
  provider = "prisma-client-js"
  // Output to the default node_modules location keeps imports portable.
}

datasource db {
  provider  = "postgresql"
  // Runtime connection — may be a pooled (PgBouncer/Supabase :6543) URL.
  url       = env("DATABASE_URL")
  // Direct, non-pooled connection used by `prisma migrate` / introspection.
  // Must be set wherever migrations run (CI release step, local dev); the
  // running app itself only needs DATABASE_URL. Point it at DATABASE_URL when
  // that connection is already direct (non-pooled).
  directUrl = env("DIRECT_URL")
}

// =============================================================================
//  ENUMS — business-state vocabularies
// =============================================================================

enum UserRole {
  CUSTOMER
  VIP
  STAFF
  ADMIN
  SUPER_ADMIN

  @@map("user_role")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  FULFILLMENT
  SUPPORT

  @@map("admin_role")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED

  @@map("order_status")
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED

  @@map("payment_status")
}

enum PaymentMethod {
  CARD
  PAYPAL
  APPLE_PAY
  GOOGLE_PAY
  KLARNA
  AFTERPAY
  BANK_TRANSFER
  COD

  @@map("payment_method")
}

enum ShipmentStatus {
  PENDING
  LABEL_CREATED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
  FAILED

  @@map("shipment_status")
}

enum DiscountType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING

  @@map("discount_type")
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED

  @@map("subscription_status")
}

enum LoyaltyTxType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTMENT
  REFERRAL

  @@map("loyalty_tx_type")
}

enum NotificationType {
  ORDER_UPDATE
  PROMOTION
  REVIEW_REQUEST
  SYSTEM
  LOYALTY
  ABANDONED_CART
  NEW_PRODUCT

  @@map("notification_type")
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  REFUNDED

  @@map("return_status")
}

// =============================================================================
//  IDENTITY & ACCESS
// =============================================================================

/// End-customers of the storefront. Operators live in `admin_users`.
model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName    String?   @map("first_name") @db.VarChar(80)
  lastName     String?   @map("last_name") @db.VarChar(80)
  email        String    @unique @db.VarChar(255)
  phone        String?   @db.VarChar(32)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         UserRole  @default(CUSTOMER)
  isVerified   Boolean   @default(false) @map("is_verified")
  profileImage String?   @map("profile_image")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  addresses          UserAddress[]
  carts              Cart[]
  wishlists          Wishlist[]
  orders             Order[]
  reviews            Review[]
  notifications      Notification[]
  recentlyViewed     RecentlyViewedProduct[]
  searchLogs         SearchLog[]
  viewLogs           ProductViewLog[]
  loyaltyPoints      LoyaltyPoint[]
  couponUsages       CouponUsage[]
  subscriptions      Subscription[]
  aiAssessments      AiSkinAssessment[]
  referralsMade      Referral[]              @relation("ReferrerRelation")
  referralsGotten    Referral[]              @relation("ReferredRelation")
  // Audit trail of order-status transitions this user triggered (admin actor).
  orderStatusChanges OrderStatusHistory[]    @relation("OrderStatusChanger")
  refreshTokens      RefreshToken[]
  returnRequests     ReturnRequest[]

  @@index([role])
  @@index([createdAt])
  @@map("users")
}

/// Server-side record of every issued refresh token, keyed by its JWT `jti`.
/// Enables rotation, revocation (logout), and reuse detection: a refresh JWT is
/// only honored if its `jti` row exists, is not revoked, and is not expired.
model RefreshToken {
  jti        String    @id @db.VarChar(64)
  userId     String    @map("user_id") @db.Uuid
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  // jti of the token that superseded this one (set on rotation); aids auditing.
  replacedBy String?   @map("replaced_by") @db.VarChar(64)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// Saved shipping / billing addresses. A user may have many; exactly one
/// per user may be flagged default (enforced by a partial unique index).
model UserAddress {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  fullName     String   @map("full_name") @db.VarChar(160)
  phone        String?  @db.VarChar(32)
  country      String   @db.VarChar(2) // ISO-3166 alpha-2
  city         String   @db.VarChar(120)
  area         String?  @db.VarChar(160)
  addressLine1 String   @map("address_line_1") @db.VarChar(255)
  addressLine2 String?  @map("address_line_2") @db.VarChar(255)
  postalCode   String?  @map("postal_code") @db.VarChar(20)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // "At most one default address per user" is enforced by a PARTIAL unique
  // index (`WHERE is_default`) created in the migration. Prisma can't express
  // partial unique constraints in the schema, so it isn't declared with
  // @@unique here — a plain composite unique on (userId, isDefault) would
  // wrongly cap each user at two addresses (one default + one non-default).
  @@index([userId])
  @@map("user_addresses")
}

/// Operators (back-office). Separated from `users` so we can apply distinct
/// security policies (MFA, IP restriction, narrower password rules).
model AdminUser {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String    @db.VarChar(160)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         AdminRole @default(EDITOR)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  activityLogs AdminActivityLog[]

  @@index([role])
  @@map("admin_users")
}

/// Append-only audit log for back-office actions.
model AdminActivityLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminUserId String   @map("admin_user_id") @db.Uuid
  action      String   @db.VarChar(64) // e.g. "update", "delete"
  module      String   @db.VarChar(64) // e.g. "products", "orders"
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([module, createdAt])
  @@map("admin_activity_logs")
}

// =============================================================================
//  CATALOG
// =============================================================================

/// Self-referential category tree (Skincare → Serums → Vitamin C, etc).
model Category {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId    String?  @map("parent_id") @db.Uuid
  name        String   @db.VarChar(160)
  slug        String   @unique @db.VarChar(180)
  description String?  @db.Text
  image       String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryParent")
  products Product[]

  @@index([parentId])
  @@index([isActive, sortOrder])
  @@map("categories")
}

model Brand {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @db.VarChar(160)
  slug        String  @unique @db.VarChar(180)
  logo        String?
  description String? @db.Text
  isActive    Boolean @default(true) @map("is_active")

  products Product[]

  @@index([isActive])
  @@map("brands")
}

/// Master product. SKU/barcode/slug are all unique. Pricing here is the
/// "from" price; actual transactable price lives on `product_variants`.
model Product {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId       String?  @map("category_id") @db.Uuid
  brandId          String?  @map("brand_id") @db.Uuid
  name             String   @db.VarChar(255)
  slug             String   @unique @db.VarChar(255)
  shortDescription String?  @map("short_description") @db.VarChar(500)
  fullDescription  String?  @map("full_description") @db.Text
  sku              String   @unique @db.VarChar(80)
  barcode          String?  @unique @db.VarChar(64)
  price            Decimal  @db.Decimal(12, 2)
  comparePrice     Decimal? @map("compare_price") @db.Decimal(12, 2)
  costPrice        Decimal? @map("cost_price") @db.Decimal(12, 2)
  isFeatured       Boolean  @default(false) @map("is_featured")
  isActive         Boolean  @default(true) @map("is_active")
  seoTitle         String?  @map("seo_title") @db.VarChar(255)
  seoDescription   String?  @map("seo_description") @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  category           Category?               @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand              Brand?                  @relation(fields: [brandId], references: [id], onDelete: SetNull)
  variants           ProductVariant[]
  images             ProductImage[]
  tagMappings        ProductTagMapping[]
  skinConcerns       ProductSkinConcern[]
  ingredients        ProductIngredient[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  wishlists          Wishlist[]
  reviews            Review[]
  recentlyViewed     RecentlyViewedProduct[]
  viewLogs           ProductViewLog[]
  stockNotifications StockNotification[]

  // CHECK constraints — non-negative pricing.
  @@index([categoryId])
  @@index([brandId])
  @@index([isActive])
  @@index([isFeatured, isActive])
  @@index([createdAt])
  // Trigram index is added in a follow-up migration for fuzzy name search.
  @@map("products")
}

/// A purchasable variant of a product: 30ml / 50ml, shade "Rose", etc.
/// Stock is held here, not on the master product.
model ProductVariant {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  size          String?  @db.VarChar(64)
  shade         String?  @db.VarChar(64)
  fragrance     String?  @db.VarChar(64)
  sku           String   @unique @db.VarChar(80)
  price         Decimal  @db.Decimal(12, 2)
  stockQuantity Int      @default(0) @map("stock_quantity")
  weight        Decimal? @db.Decimal(8, 3) // kilograms — for shipping rate calc
  isActive      Boolean  @default(true) @map("is_active")

  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  images             ProductImage[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  stockNotifications StockNotification[]

  @@index([productId])
  @@index([isActive])
  @@index([stockQuantity])
  @@map("product_variants")
}

/// Product gallery. Image may be attached to a variant (e.g. swatch) or to
/// the master product (lifestyle, packshot).
model ProductImage {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  variantId String? @map("variant_id") @db.Uuid
  imageUrl  String  @map("image_url")
  altText   String? @map("alt_text") @db.VarChar(255)
  isPrimary Boolean @default(false) @map("is_primary")
  sortOrder Int     @default(0) @map("sort_order")

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@index([variantId])
  @@map("product_images")
}

/// Free-form, merchandiser-controlled product tags ("New", "Vegan", "Editor's pick").
model ProductTag {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @db.VarChar(80)
  slug String @unique @db.VarChar(100)

  productMappings ProductTagMapping[]

  @@map("product_tags")
}

model ProductTagMapping {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String @map("product_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid

  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId], map: "uq_product_tag")
  @@index([tagId])
  @@map("product_tag_mappings")
}

// =============================================================================
//  COSMETICS-SPECIFIC ATTRIBUTES
// =============================================================================

/// Skincare concerns powering filters and the AI assistant
/// (Acne, Hyperpigmentation, Aging, Sensitivity, ...).
model SkinConcern {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @db.VarChar(120)
  slug String @unique @db.VarChar(140)

  products ProductSkinConcern[]

  @@map("skin_concerns")
}

model ProductSkinConcern {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     String @map("product_id") @db.Uuid
  skinConcernId String @map("skin_concern_id") @db.Uuid

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  skinConcern SkinConcern @relation(fields: [skinConcernId], references: [id], onDelete: Cascade)

  @@unique([productId, skinConcernId], map: "uq_product_skin_concern")
  @@index([skinConcernId])
  @@map("product_skin_concerns")
}

/// INCI ingredient registry — feeds product detail pages and "free from" filters.
model Ingredient {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @db.VarChar(160)
  slug        String  @unique @db.VarChar(180)
  description String? @db.Text

  products ProductIngredient[]

  @@map("ingredients")
}

model ProductIngredient {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String @map("product_id") @db.Uuid
  ingredientId String @map("ingredient_id") @db.Uuid

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId], map: "uq_product_ingredient")
  @@index([ingredientId])
  @@map("product_ingredients")
}

// =============================================================================
//  COMMERCE — Cart, Wishlist
// =============================================================================

/// A cart belongs to a logged-in user OR (for guests) a session_id.
/// Exactly one is required — enforced by a CHECK constraint at the DB layer.
model Cart {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?   @map("user_id") @db.Uuid
  sessionId      String?   @map("session_id") @db.VarChar(80)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  // When the last abandoned-cart recovery email was sent. Null until a reminder
  // is sent; the cart becomes re-eligible once it changes after this time.
  reminderSentAt DateTime? @map("reminder_sent_at") @db.Timestamptz

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@unique([userId], map: "uq_user_active_cart")
  @@unique([sessionId], map: "uq_session_active_cart")
  @@index([updatedAt])
  @@map("carts")
}

/// Cart line. `price` is the price snapshot at time-of-add — protects the
/// shopper from price changes between viewing and checkout.
model CartItem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String  @map("cart_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  variantId String? @map("variant_id") @db.Uuid
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(12, 2)

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId], map: "uq_cart_line")
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model Wishlist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId], map: "uq_wishlist_user_product")
  @@index([productId])
  @@map("wishlists")
}

/// "Notify me when back in stock" waitlist for an out-of-stock variant. Works
/// for guests (email only) and logged-in users. One row per (variant, email);
/// `notifiedAt` is set once the restock email is sent.
model StockNotification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId  String    @map("variant_id") @db.Uuid
  productId  String    @map("product_id") @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  email      String    @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  notifiedAt DateTime? @map("notified_at") @db.Timestamptz

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([variantId, email], map: "uq_stock_notify")
  @@index([variantId, notifiedAt])
  @@map("stock_notifications")
}

// =============================================================================
//  COMMERCE — Orders, Payments, Shipments
// =============================================================================

/// Customer-facing order. `order_number` is a human-readable identifier
/// (e.g. "ELV-2026-000142") generated in application code; `id` is the PK.
model Order {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?       @map("user_id") @db.Uuid
  orderNumber     String        @unique @map("order_number") @db.VarChar(32)
  orderStatus     OrderStatus   @default(PENDING) @map("order_status")
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  subtotal        Decimal       @db.Decimal(12, 2)
  shippingFee     Decimal       @default(0) @map("shipping_fee") @db.Decimal(12, 2)
  taxAmount       Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  /// Human label for the applied discount ("Spend & Save", a coupon code, …) —
  /// null when no discount. Lets receipts/admin show the source without a join.
  discountLabel   String?       @map("discount_label") @db.VarChar(64)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(12, 2)
  currency        String        @default("PKR") @db.VarChar(3)
  notes           String?       @db.Text
  /// Set exactly once when a cancel/return/refund restores this order's stock,
  /// so concurrent paths (admin action, Stripe webhook) can't double-restock.
  stockRestoredAt DateTime?     @map("stock_restored_at") @db.Timestamptz
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz

  // ---- Shipping address snapshot ----------------------------------------
  // Denormalized inline so the order stays immutable even if the customer
  // later edits or deletes the source UserAddress. All fields are nullable
  // for backward-compat with historic test orders placed before this column
  // set existed; new orders populate them via `placeOrder`.
  shippingFullName     String? @map("shipping_full_name") @db.VarChar(160)
  shippingEmail        String? @map("shipping_email") @db.VarChar(255)
  shippingPhone        String? @map("shipping_phone") @db.VarChar(32)
  shippingCountry      String? @map("shipping_country") @db.VarChar(2)
  shippingCity         String? @map("shipping_city") @db.VarChar(120)
  shippingArea         String? @map("shipping_area") @db.VarChar(160)
  shippingAddressLine1 String? @map("shipping_address_line_1") @db.VarChar(255)
  shippingAddressLine2 String? @map("shipping_address_line_2") @db.VarChar(255)
  shippingPostalCode   String? @map("shipping_postal_code") @db.VarChar(20)

  user          User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  payments      Payment[]
  shipments     Shipment[]
  couponUsages  CouponUsage[]
  returnRequest ReturnRequest?

  @@index([userId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("orders")
}

/// Customer-initiated return / refund request for a delivered order. One per
/// order (v1, order-level). The admin moves it through REQUESTED → APPROVED →
/// REFUNDED (or REJECTED); marking REFUNDED also flips the order to REFUNDED.
model ReturnRequest {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId    String       @unique @map("order_id") @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  status     ReturnStatus @default(REQUESTED)
  reason     String       @db.VarChar(120)
  comment    String?      @db.Text
  adminNote  String?      @map("admin_note") @db.Text
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  resolvedAt DateTime?    @map("resolved_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId])
  @@map("return_requests")
}

/// Order line item. We snapshot `product_name`, `variant_name`, `unit_price`
/// so the order is immutable even if the catalog changes later.
model OrderItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  productId   String? @map("product_id") @db.Uuid
  variantId   String? @map("variant_id") @db.Uuid
  productName String  @map("product_name") @db.VarChar(255)
  variantName String? @map("variant_name") @db.VarChar(255)
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

/// Status-change audit trail for every order.
model OrderStatusHistory {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String      @map("order_id") @db.Uuid
  status    OrderStatus
  note      String?     @db.Text
  /// Actor who triggered the change. Points to `users.id` (admins live in the
  /// users table — `users.role` ∈ {ADMIN, SUPER_ADMIN, STAFF}). Nullable for
  /// system / webhook-driven transitions (e.g. payment-succeeded → CONFIRMED).
  changedBy String?     @map("changed_by") @db.Uuid
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz

  order         Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser User? @relation("OrderStatusChanger", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

/// One row per payment attempt; an order can have multiple (auth, capture,
/// refund) so we don't overwrite history.
model Payment {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String        @map("order_id") @db.Uuid
  paymentMethod PaymentMethod @map("payment_method")
  transactionId String?       @unique @map("transaction_id") @db.VarChar(120)
  amount        Decimal       @db.Decimal(12, 2)
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  paidAt        DateTime?     @map("paid_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([paymentStatus])
  @@map("payments")
}

/// Carrier dispatch + tracking. One order may ship in multiple parcels.
model Shipment {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String         @map("order_id") @db.Uuid
  courierName    String         @map("courier_name") @db.VarChar(120)
  trackingNumber String?        @unique @map("tracking_number") @db.VarChar(120)
  shipmentStatus ShipmentStatus @default(PENDING) @map("shipment_status")
  shippedAt      DateTime?      @map("shipped_at") @db.Timestamptz
  deliveredAt    DateTime?      @map("delivered_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([shipmentStatus])
  @@map("shipments")
}

// =============================================================================
//  REVIEWS & UGC
// =============================================================================

/// Product review. Star rating is constrained to 1-5 via CHECK.
/// `is_verified_purchase` is set at write time after looking up the order_items.
model Review {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Null for verified-purchase GUEST reviews (accounts are optional). A guest
  /// review is instead bound to its purchase via `orderId` + `authorName`.
  userId             String?  @map("user_id") @db.Uuid
  /// The order this review is for — set on guest reviews. No FK (analytics-style:
  /// deleting an order must not cascade-remove its reviews). Enforces one review
  /// per (order, product) via the unique index below.
  orderId            String?  @map("order_id") @db.Uuid
  /// Display name for guest reviews (taken from the order's shipping name).
  authorName         String?  @map("author_name") @db.VarChar(160)
  productId          String   @map("product_id") @db.Uuid
  rating             Int
  title              String?  @db.VarChar(200)
  comment            String?  @db.Text
  isVerifiedPurchase Boolean  @default(false) @map("is_verified_purchase")
  isApproved         Boolean  @default(false) @map("is_approved") // moderation gate
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  images  ReviewImage[]

  @@unique([userId, productId], map: "uq_review_user_product")
  @@unique([orderId, productId], map: "uq_review_order_product")
  @@index([productId, isApproved])
  @@index([createdAt])
  @@map("reviews")
}

model ReviewImage {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewId String @map("review_id") @db.Uuid
  imageUrl String @map("image_url")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_images")
}

// =============================================================================
//  MARKETING — Coupons, Banners, Blog, Newsletter
// =============================================================================

model Coupon {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String       @unique @db.VarChar(64)
  discountType       DiscountType @map("discount_type")
  discountValue      Decimal      @map("discount_value") @db.Decimal(12, 2)
  minimumOrderAmount Decimal?     @map("minimum_order_amount") @db.Decimal(12, 2)
  maximumDiscount    Decimal?     @map("maximum_discount") @db.Decimal(12, 2)
  usageLimit         Int?         @map("usage_limit") // null = unlimited
  usedCount          Int          @default(0) @map("used_count")
  startsAt           DateTime?    @map("starts_at") @db.Timestamptz
  expiresAt          DateTime?    @map("expires_at") @db.Timestamptz
  isActive           Boolean      @default(true) @map("is_active")

  usages CouponUsage[]

  @@index([isActive, expiresAt])
  @@map("coupons")
}

/// One row per redemption — used to enforce per-user usage caps.
model CouponUsage {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couponId String   @map("coupon_id") @db.Uuid
  userId   String?  @map("user_id") @db.Uuid
  orderId  String?  @map("order_id") @db.Uuid
  usedAt   DateTime @default(now()) @map("used_at") @db.Timestamptz

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([couponId])
  @@index([userId])
  @@index([orderId])
  @@map("coupon_usages")
}

/// "Spend & Save" — automatic, cart-level discount tiers. When the subtotal
/// reaches `minSubtotal`, `discountAmount` comes off. The highest qualifying
/// active tier wins; the app compares it against any coupon and applies the
/// larger (best-single-wins). Managed from /admin/coupons.
model SpendDiscountTier {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  minSubtotal    Decimal  @map("min_subtotal") @db.Decimal(12, 2)
  discountAmount Decimal  @map("discount_amount") @db.Decimal(12, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([isActive, minSubtotal])
  @@map("spend_discount_tiers")
}

/// Generic key/value store for store-wide toggles (e.g. the Spend & Save
/// master switch, `spend_discount.enabled`). Small, reusable — not per-user.
model AppSetting {
  key       String   @id @db.VarChar(64)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("app_settings")
}

model Banner {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String    @db.VarChar(200)
  imageUrl    String    @map("image_url")
  redirectUrl String?   @map("redirect_url")
  position    String    @db.VarChar(64) // e.g. "homepage_hero", "category_top"
  isActive    Boolean   @default(true) @map("is_active")
  startsAt    DateTime? @map("starts_at") @db.Timestamptz
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz

  @@index([position, isActive])
  @@index([isActive, expiresAt])
  @@map("banners")
}

model BlogCategory {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @db.VarChar(160)
  slug String @unique @db.VarChar(180)

  posts BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId     String?   @map("category_id") @db.Uuid
  title          String    @db.VarChar(255)
  slug           String    @unique @db.VarChar(255)
  thumbnail      String?
  content        String    @db.Text
  seoTitle       String?   @map("seo_title") @db.VarChar(255)
  seoDescription String?   @map("seo_description") @db.VarChar(500)
  isPublished    Boolean   @default(false) @map("is_published")
  publishedAt    DateTime? @map("published_at") @db.Timestamptz

  category BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([isPublished, publishedAt])
  @@map("blog_posts")
}

model NewsletterSubscriber {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  subscribedAt DateTime @default(now()) @map("subscribed_at") @db.Timestamptz

  @@index([isActive])
  @@map("newsletter_subscribers")
}

// =============================================================================
//  NOTIFICATIONS
// =============================================================================

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(200)
  message   String           @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

// =============================================================================
//  ANALYTICS — write-heavy logs
// =============================================================================

/// Last-N viewed products per user. App layer trims to a fixed window
/// (e.g. 20 newest) on insert.
model RecentlyViewedProduct {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  viewedAt  DateTime @default(now()) @map("viewed_at") @db.Timestamptz

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId], map: "uq_recently_viewed_user_product")
  @@index([userId, viewedAt(sort: Desc)])
  @@map("recently_viewed_products")
}

/// Search-bar query log. Powers "trending" and zero-result analysis.
model SearchLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  keyword     String   @db.VarChar(255)
  resultCount Int      @default(0) @map("result_count")
  searchedAt  DateTime @default(now()) @map("searched_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([keyword])
  @@index([searchedAt])
  @@index([userId, searchedAt])
  @@map("search_logs")
}

/// Granular pageview log — high volume. Consider partitioning by month
/// in production via a migration that adds PARTITION BY RANGE (viewed_at).
model ProductViewLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  viewedAt  DateTime @default(now()) @map("viewed_at") @db.Timestamptz

  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, viewedAt])
  @@index([userId, viewedAt])
  @@map("product_view_logs")
}

/// Append-only log of "add to cart" events, for merchandising analytics.
/// Relation-less (plain id columns): analytics tolerates orphaned rows and we
/// join product details at query time, so product/variant deletion needn't
/// cascade here.
model CartEventLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  variantId String?  @map("variant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([productId, createdAt])
  @@index([userId, createdAt])
  @@map("cart_event_logs")
}

/// Append-only first-party clickstream — "who clicked what, when". High volume,
/// so it's deliberately narrow and relation-less (plain id columns, joined at
/// query time) like CartEventLog: analytics tolerates orphaned rows and we don't
/// want product/user deletion to cascade-scan this table. A retention job trims
/// rows older than CLICKSTREAM_RETENTION_DAYS; consider monthly
/// PARTITION BY RANGE (created_at) via a migration if volume warrants.
model ClickEventLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Logged-in user, when known. No FK so a user delete needn't touch this table.
  userId     String?  @map("user_id") @db.Uuid
  /// Guest-session anchor (elv_guest cookie) for pre-login attribution.
  guestId    String?  @map("guest_id") @db.VarChar(64)
  /// Semantic bucket: product | nav | cta | banner | link | button | other.
  targetType String   @map("target_type") @db.VarChar(24)
  /// Stable id for the thing clicked (productId, or a data-track-id). Null when
  /// the element carries no explicit id.
  targetId   String?  @map("target_id") @db.VarChar(128)
  /// Human label (trimmed text / aria-label / data-track-label), PII-stripped.
  label      String?  @db.VarChar(160)
  /// Destination for links (query string stripped). Null for buttons.
  href       String?  @db.VarChar(512)
  /// Path where the click happened (location.pathname).
  pagePath   String   @map("page_path") @db.VarChar(512)
  /// Index within a list/grid, when the element exposes data-index.
  position   Int?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt])
  @@index([targetType, createdAt])
  @@index([targetId, createdAt])
  @@index([userId, createdAt])
  @@map("click_event_logs")
}

// =============================================================================
//  LOYALTY, REFERRALS, SUBSCRIPTIONS
// =============================================================================

/// Append-only ledger of points changes. Current balance =
/// SUM(points) for a user. Type makes the change semantically queryable.
model LoyaltyPoint {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  points          Int // signed: + earned / − redeemed
  transactionType LoyaltyTxType @map("transaction_type")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("loyalty_points")
}

model Referral {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referrerUserId String   @map("referrer_user_id") @db.Uuid
  referredUserId String   @map("referred_user_id") @db.Uuid
  rewardPoints   Int      @default(0) @map("reward_points")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  referrer User @relation("ReferrerRelation", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referred User @relation("ReferredRelation", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([referredUserId], map: "uq_referred_user_once")
  @@index([referrerUserId])
  @@map("referrals")
}

model Subscription {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String             @map("user_id") @db.Uuid
  subscriptionType String             @map("subscription_type") @db.VarChar(64) // e.g. "ELVIORA_INSIDER_ANNUAL"
  startDate        DateTime           @map("start_date") @db.Timestamptz
  endDate          DateTime?          @map("end_date") @db.Timestamptz
  status           SubscriptionStatus @default(ACTIVE)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

// =============================================================================
//  AI SKINCARE ASSISTANT
// =============================================================================

/// Captured assessment from the AI concierge — feeds personalization.
/// `concerns` and `recommendations` are JSON for flexibility as the model
/// evolves; promote to relational tables when shape stabilizes.
model AiSkinAssessment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  /// Lead email for guest quiz-takers (no account) — makes them a reachable
  /// marketing segment / Meta Custom Audience seed.
  email           String?  @db.VarChar(255)
  skinType        String?  @map("skin_type") @db.VarChar(32) // e.g. "oily", "combination"
  concerns        Json?
  recommendations Json?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([email])
  @@map("ai_skin_assessments")
}

// =============================================================================
//  SYSTEM — Settings (KV store)
// =============================================================================

model Setting {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String   @unique @db.VarChar(120)
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("settings")
}
